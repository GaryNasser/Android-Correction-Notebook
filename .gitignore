# --- Build 产物 (编译生成的临时文件，最占空间且不需要上传) ---
build/
*/build/
bin/
gen/
out/
.gradle/
.kotlin/

# --- IDE 配置文件 (Android Studio / IntelliJ) ---
# 建议忽略大部分 .idea 文件夹，因为它们包含你的本地路径和窗口布局
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/navEditor.xml
.idea/deploymentTargetSelector.xml
*.iml
*.iws
*.ipr

# --- 本地配置文件 (绝对不能上传，包含你的 SDK 路径或密钥) ---
local.properties
.navigation/

# --- 签名文件 (私钥，千万不要上传到 GitHub！) ---
*.jks
*.keystore
*.p12
*.key
*.pub

# --- 测试与捕获 ---
captures/
.externalNativeBuild/
.cxx/
cmake-build-*/

# --- 操作系统临时文件 ---
.DS_Store
Thumbs.db

# --- 日志文件 ---
*.log

